#include <stdio.h>
#include <stdbool.h>
#include <string.h>
#include <assert.h>

// Mock get_pixel function for testing
void (*mock_get_pixel)(int, int, unsigned char*, unsigned char*, unsigned char*) = NULL;

void get_pixel(int row, int col, unsigned char *r, unsigned char *g, unsigned char *b) {
    if (mock_get_pixel) {
        mock_get_pixel(row, col, r, g, b);
    }
}

void mock_no_ruby(int row, int col,
                  unsigned char *r,
                  unsigned char *g,
                  unsigned char *b) {
    *r = 10;
    *g = 10;
    *b = 10;
}

// Test 1: No ruby detected (insufficient red pixels)
void test_no_ruby_detected() {
    printf("Test 1: No ruby detected...\n");
    
    bool rubyDetected = false;
    bool rubyMoved = false;
    bool attemptedTheft = false;
    int prevCenterRow = -1;
    int prevCenterCol = -1;
    
    // Mock: all pixels are black/noise
    mock_get_pixel = mock_no_ruby;
    
    trackRuby(&rubyDetected, &rubyMoved, &attemptedTheft, &prevCenterRow, &prevCenterCol);
    
    assert(rubyDetected == false);
    assert(attemptedTheft == true);
    printf("✓ Test 1 passed\n\n");
}

void mock_center_ruby(int row, int col,
                      unsigned char *r,
                      unsigned char *g,
                      unsigned char *b) {

    if (row >= 230 && row <= 250 &&
        col >= 310 && col <= 330) {

        *r = 200;
