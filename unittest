void mock_ruby_small_motion(int row, int col, unsigned char *r, unsigned char *g, unsigned char *b) {
        if (row >= 245 && row <= 265 && col >= 325 && col <= 345) {
            *r = 200; *g = 50; *b = 50;
        } else {
            *r = 10; *g = 10; *b = 10;
        }
    };

// Test 4: Ruby detected with small displacement (motion accumulation)
void test_ruby_small_displacement() {
    printf("Test 4: Ruby with small displacement \n");
    
    bool rubyDetected = false;
    bool rubyMoved = false;
    bool attemptedTheft = false;
    int prevCenterRow = 240;
    int prevCenterCol = 320;
    
    // Mock: small movement from previous position
    mock_get_pixel = mock_ruby_small_motion;
    
    // First call with small displacement
    trackRuby(&rubyDetected, &rubyMoved, &attemptedTheft, &prevCenterRow, &prevCenterCol);
    assert(rubyDetected == true);
    
    // Multiple small displacements should accumulate
    for (int i = 0; i < 3; i++) {
        trackRuby(&rubyDetected, &rubyMoved, &attemptedTheft, &prevCenterRow, &prevCenterCol);
    }
    
    assert(rubyMoved == true);
    assert(attemptedTheft == true);
    printf("✓ Test 4 passed\n\n");
}

